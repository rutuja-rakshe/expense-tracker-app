# ─── Django Core ───────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database (local dev) ──────────────────────────────────
DB_NAME=expense_tracker
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# OR use DATABASE_URL (takes priority, required for RDS in prod)
# DATABASE_URL=postgres://user:password@rds-endpoint.amazonaws.com:5432/expense_tracker

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ───────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ─── CORS ──────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── AWS (production only) ─────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=expense-tracker-media
AWS_S3_REGION_NAME=us-east-1
USE_S3=False

# ─── Email / SES (production only) ────────────────────────
EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ─── Sentry (production only) ──────────────────────────────
SENTRY_DSN=

# ─── SSL ───────────────────────────────────────────────────
SECURE_SSL_REDIRECT=False